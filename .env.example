# Copy this file to .env (root app) and fill in real values.
# The worker/ process reads the same DATABASE_URL — see worker/README notes in plan.md Phase 8/11.

# ── Database ──────────────────────────────────────────────────────────────
# MySQL connection string used by Prisma (prisma/schema.prisma).
DATABASE_URL="mysql://user:password@localhost:3306/estudyou"

# ── NextAuth v5 ───────────────────────────────────────────────────────────
# Required in production. Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Set to "true" only if the app sits behind a reverse proxy/load balancer
# (Railway, Render, Fly, etc.) so NextAuth trusts the forwarded host/proto.
AUTH_TRUST_HOST="true"

# ── Stripe ────────────────────────────────────────────────────────────────
# Server-side secret key (sk_test_... in dev, sk_live_... in production).
STRIPE_SECRET_KEY=""
# Publishable key exposed to the browser (pk_test_... / pk_live_...).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Signing secret for the /api/webhooks/stripe endpoint (from the Stripe
# dashboard or `stripe listen` in local dev).
STRIPE_WEBHOOK_SECRET=""

# ── Nextcloud (teacher account provisioning at registration) ─────────────
# See app/lib/auth/register-teacher.ts. Base URL of the Nextcloud instance,
# plus an admin account used to provision per-teacher Nextcloud users.
NEXTCLOUD_URL=""
NEXTCLOUD_USERNAME=""
NEXTCLOUD_PASSWORD=""

# ── Resend (transactional email) ─────────────────────────────────────────
# Used for email verification / password reset — see plan.md Phase 11A.
RESEND_API_KEY=""
# "From" address for outgoing mail. Must be a verified sender/domain in the
# Resend dashboard for production; the resend.dev sandbox address below only
# delivers to your own Resend account email in dev/test.
RESEND_FROM_EMAIL="eStudyou <onboarding@resend.dev>"

# ── App URL ───────────────────────────────────────────────────────────────
# Absolute base URL used to build links in emails (verification, password
# reset). Set to the real production origin when deployed.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
