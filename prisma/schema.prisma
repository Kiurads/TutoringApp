datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RegularClassStatus {
  active
  inactive
}

enum Status {
  requested
  scheduled
  completed
  refused
}

enum Role {
  admin
  student
  teacher
}

model User {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  email         String    @unique
  emailVerified DateTime?
  password      String
  image         String?
  phoneNumber   String?
  accounts      Account[]
  sessions      Session[]
  role          Role      @default(student)
  bio           String?

  // Teacher-specific fields
  pricePerHour   Decimal?
  teacherRating  TeacherRating[]  @relation("TeacherRatingStudent")
  teacherSubject TeacherSubject[]

  // Optional for WebAuthn support
  Authenticator Authenticator[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  classesAsStudent        Class[]         @relation("Student")
  classesAsTeacher        Class[]         @relation("Teacher")
  classesAsRequester      Class[]         @relation("Requester")
  regularClassesAsStudent RegularClass[]  @relation("RegularClassStudent")
  regularClassesAsTeacher RegularClass[]  @relation("RegularClassTeacher")
  teacherRatingsAsTeacher TeacherRating[] @relation("TeacherRatingTeacher")
  paymentsAsStudent       Payment[]       @relation("PaymentStudent")
  paymentsAsTeacher       Payment[]       @relation("PaymentTeacher")
}

model Subject {
  id             String           @id @default(cuid())
  name           String           @unique
  teacherSubject TeacherSubject[]
  class          Class[]
  regularClass   RegularClass[]
}

model TeacherSubject {
  id        String @id @default(cuid())
  teacherId String
  subjectId String

  teacher User    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])
}

model Class {
  id              String   @id @default(cuid())
  studentId       String
  teacherId       String
  subjectId       String
  startTime       DateTime
  durationInHours Decimal
  totalPrice      Decimal
  status          Status   @default(requested)
  paid            Boolean  @default(false)
  requesterId     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student       User            @relation("Student", fields: [studentId], references: [id], onDelete: Cascade)
  teacher       User            @relation("Teacher", fields: [teacherId], references: [id], onDelete: Cascade)
  requester     User            @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  subject       Subject         @relation(fields: [subjectId], references: [id])
  teacherRating TeacherRating[]
  payments      Payment[]

  @@index([studentId])
  @@index([teacherId])
  @@index([status])
}

model RegularClass {
  id              String             @id @default(cuid())
  studentId       String
  teacherId       String
  subjectId       String
  dayOfWeek       Int
  startTime       DateTime
  durationInHours Decimal
  totalPrice      Decimal
  status          RegularClassStatus @default(active)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  student User    @relation("RegularClassStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher User    @relation("RegularClassTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@index([studentId])
  @@index([teacherId])
}

model TeacherRating {
  id        String   @id @default(cuid())
  studentId String
  teacherId String
  classId   String
  rating    Int      @default(5)
  review    String?
  createdAt DateTime @default(now())

  student User  @relation("TeacherRatingStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher User  @relation("TeacherRatingTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([teacherId])
}

model Payment {
  id           String   @id @default(cuid())
  studentId    String
  teacherId    String
  classId      String
  amount       Decimal
  intentId     String
  createdAt    DateTime @default(now())

  student User  @relation("PaymentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher User  @relation("PaymentTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([teacherId])
  @@index([classId])
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String  @unique
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?
  user                     User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}
