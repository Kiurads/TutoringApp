datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RegularClassStatus {
  requested
  active
  inactive
}

enum Status {
  requested
  scheduled
  completed
  refused
}

enum Role {
  admin
  student
  teacher
}

enum NotificationType {
  class_requested
  class_accepted
  class_refused
  class_cancelled
  class_claimed
  class_paid
  class_completed
  tier_up
  rank_up
  badge_earned
  gem_received
  sparks_received
  streak_saved
  counter_offer_proposed
  counter_offer_accepted
  counter_offer_declined
  refund_requested
  refund_decided
  refund_escalated
  refund_resolved
  regular_class_requested
  regular_class_accepted
  regular_class_refused
  regular_class_cancelled
  payout_sent
}

enum BadgeCategory {
  subject
  engagement
  milestone
  expertise
  pedagogy
}

enum RefundRequestStatus {
  pending
  accepted
  refused
  expired
  admin_review
  resolved
}

// Stripe Connect Express account status for a teacher's payouts.
enum ConnectStatus {
  not_started // no Stripe account created yet
  pending     // account created, onboarding link sent, not yet fully verified
  restricted  // Stripe requires more info (charges/payouts disabled)
  active      // charges_enabled && payouts_enabled && details_submitted
}

// Tracks whether a captured class Payment's teacher cut has been sent via
// Stripe Connect. Separate from ConnectStatus: a teacher can be "active" but
// an individual payout can still be "pending" (e.g. the class hasn't
// completed yet) or "failed" (e.g. a transient Stripe error).
enum PayoutStatus {
  not_applicable // default; becomes meaningful once the class completes
  pending        // class completed, but teacher not yet onboarded — accrued
  transferred    // stripe.transfers.create succeeded
  failed         // transfer attempted and errored
}

model User {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  email         String    @unique
  emailVerified DateTime?
  password      String
  image         String?
  phoneNumber   String?
  accounts      Account[]
  sessions      Session[]
  role          Role      @default(student)
  bio           String?
  // Gates the one-time welcome tour + preferences prompt shown on first
  // login — see app/ui/onboarding/welcome-tour-modal.tsx. Deliberately
  // separate from learningStyle/teachingStyle being set: preferences stay
  // freely revisitable afterward and are never re-forced on the user, this
  // flag only controls whether the *tour itself* has been seen once.
  hasCompletedOnboarding Boolean @default(false)

  // Teacher-specific fields
  isOnline       Boolean  @default(false)
  pricePerHour   Decimal?
  teachingStyle  String?
  teacherRating  TeacherRating[]  @relation("TeacherRatingStudent")
  teacherSubject TeacherSubject[]

  // Stripe Connect (teacher payouts) — see app/lib/payouts.ts. No separate
  // Teacher model exists, so like pricePerHour/teachingStyle this lives on
  // User even though it's only ever populated for role: teacher.
  stripeConnectAccountId  String?       @unique
  connectStatus           ConnectStatus @default(not_started)
  connectChargesEnabled   Boolean       @default(false)
  connectPayoutsEnabled   Boolean       @default(false)
  connectDetailsSubmitted Boolean       @default(false)
  connectUpdatedAt        DateTime?

  // Student-specific fields
  learningStyle  String?
  learningGoal   String?
  avatarFrame    String?
  avatarOptions  String?   @db.Text // JSON: AvatarOptions (toon-head customization)

  // Optional for WebAuthn support
  Authenticator Authenticator[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  classesAsStudent        Class[]              @relation("Student")
  classesAsTeacher        Class[]              @relation("Teacher")
  classesAsRequester      Class[]              @relation("Requester")
  regularClassesAsStudent RegularClass[]       @relation("RegularClassStudent")
  regularClassesAsTeacher RegularClass[]       @relation("RegularClassTeacher")
  teacherRatingsAsTeacher TeacherRating[]      @relation("TeacherRatingTeacher")
  paymentsAsStudent       Payment[]            @relation("PaymentStudent")
  paymentsAsTeacher       Payment[]            @relation("PaymentTeacher")
  refundRequestsAsStudent RefundRequest[]      @relation("RefundRequestStudent")
  refundRequestsAsTeacher RefundRequest[]      @relation("RefundRequestTeacher")
  notifications           Notification[]
  studentGameProfile      StudentGameProfile?
  teacherGameProfile      TeacherGameProfile?
  userBadges              UserBadge[]
  teacherAvailability     TeacherAvailability[]
  questClaims             QuestClaim[]
}

model Subject {
  id             String           @id @default(cuid())
  name           String           @unique
  teacherSubject TeacherSubject[]
  class          Class[]
  regularClass   RegularClass[]
}

model TeacherSubject {
  id        String @id @default(cuid())
  teacherId String
  subjectId String

  teacher User    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])
}

model Class {
  id              String   @id @default(cuid())
  studentId       String
  teacherId       String?
  subjectId       String
  startTime       DateTime
  durationInHours Decimal
  totalPrice      Decimal  @default(0)
  status          Status   @default(requested)
  paid              Boolean  @default(false)
  preAuthIntentId   String?
  requesterId       String
  // Running totals of gamification points actually awarded for this class
  // (accept bonus + completion bonus can both contribute), so a refund can
  // claw back exactly what was given regardless of which award path fired —
  // the amounts differ between the worker's auto-complete and the manual
  // "Mark Complete" action, so they can't be safely re-derived after the fact.
  gemsAwarded       Int      @default(0)
  sparksAwarded     Int      @default(0)
  pointsReversed    Boolean  @default(false)
  counterOfferTime  DateTime?
  priority          Boolean  @default(false)
  jitsiRoom         String?  @unique
  regularClassId    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  student       User            @relation("Student", fields: [studentId], references: [id], onDelete: Cascade)
  teacher       User?           @relation("Teacher", fields: [teacherId], references: [id], onDelete: Cascade)
  requester     User            @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  subject       Subject         @relation(fields: [subjectId], references: [id])
  teacherRating TeacherRating[]
  payments      Payment[]
  refundRequest RefundRequest?
  regularClass  RegularClass?   @relation(fields: [regularClassId], references: [id], onDelete: SetNull)

  @@unique([regularClassId, startTime])
  @@index([studentId])
  @@index([teacherId])
  @@index([status])
  @@index([regularClassId])
}

model RefundRequest {
  id         String               @id @default(cuid())
  classId    String               @unique
  studentId  String
  teacherId  String
  reason     String               @db.Text
  status     RefundRequestStatus  @default(pending)
  adminNote  String?              @db.Text
  expiresAt  DateTime
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  student User  @relation("RefundRequestStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher User  @relation("RefundRequestTeacher", fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([studentId])
  @@index([teacherId])
}

model RegularClass {
  id                      String             @id @default(cuid())
  studentId               String
  teacherId               String
  subjectId               String
  dayOfWeek               Int
  startTime               DateTime
  durationInHours         Decimal
  totalPrice              Decimal
  status                  RegularClassStatus @default(requested)
  lastMaterializedThrough DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  student     User    @relation("RegularClassStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher     User    @relation("RegularClassTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  subject     Subject @relation(fields: [subjectId], references: [id])
  occurrences Class[]

  @@index([studentId])
  @@index([teacherId])
}

model TeacherRating {
  id        String   @id @default(cuid())
  studentId String
  teacherId String
  classId   String
  rating    Decimal  @default(5)
  review    String?
  createdAt DateTime @default(now())

  student User  @relation("TeacherRatingStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher User  @relation("TeacherRatingTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId])
  @@index([teacherId])
}

model Payment {
  id           String   @id @default(cuid())
  studentId    String
  teacherId    String
  classId      String
  amount       Decimal
  intentId     String
  createdAt    DateTime @default(now())

  // Commission split — computed once via computeCommissionSplit() at the
  // same time this row is created (i.e. at charge/capture time), and never
  // recomputed later, so a future rate change never silently reprices a
  // historical payment. Nullable only so pre-migration rows stay valid;
  // the migration backfills them immediately.
  platformFeeAmount   Decimal?
  teacherPayoutAmount Decimal?
  platformFeeRateBps  Int?

  // Payout tracking — mutated later, at class-completion time, by
  // app/lib/payouts.ts's transferPayoutForClass.
  payoutStatus      PayoutStatus @default(not_applicable)
  transferId        String?
  payoutAttemptedAt DateTime?
  payoutError       String?      @db.Text

  student User  @relation("PaymentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher User  @relation("PaymentTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([teacherId])
  @@index([classId])
  @@index([payoutStatus])
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String  @unique
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?
  user                     User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

// ── Gamification ─────────────────────────────────────────────────────────────

model StudentGameProfile {
  id                 String    @id @default(cuid())
  userId             String    @unique
  insightGems        Int       @default(0)
  learningTier       Int       @default(0) // 0=Aspiring 1=Dedicated 2=Scholar 3=Luminary 4=Sage
  // Weekly (not daily) activity streak — tutoring's natural cadence is
  // weekly/biweekly sessions, not daily practice, so a Duolingo-style daily
  // streak would punish normal usage. "A week with a completed class" is the
  // unit. streakFreezes lets a missed week be covered instead of resetting
  // to 0 — earned for free at streak milestones, not sold as anxiety relief.
  currentStreakWeeks Int       @default(0)
  longestStreakWeeks Int       @default(0)
  streakFreezes      Int       @default(0)
  lastActivityAt     DateTime?
  ownedFrames        String    @default("")  // comma-separated frame keys
  activeFrame        String?                // currently equipped frame key (null = none)
  studyBoostActive   Boolean   @default(false)
  priorityBooking    Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TeacherGameProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  reputationSparks   Int      @default(0)
  mentorshipRank     Int      @default(0) // 0=Associate 1=Senior 2=Master 3=Elite 4=Global Lead
  profileCompleted   Boolean  @default(false)
  // Same weekly-streak mechanic as StudentGameProfile — see there for why.
  currentStreakWeeks Int      @default(0)
  longestStreakWeeks Int      @default(0)
  streakFreezes      Int      @default(0)
  lastActivityAt     DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id          String        @id @default(cuid())
  key         String        @unique
  name        String
  description String
  iconKey     String
  category    BadgeCategory
  userBadges  UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
}

// Records a claimed reward for one of the fixed weekly quests (see
// app/lib/quests.ts) — quest progress itself is computed live from Class/
// TeacherRating rows, not tracked here; this table only exists to make
// claiming idempotent (one claim per user per quest per week).
model QuestClaim {
  id         String   @id @default(cuid())
  userId     String
  questKey   String
  weekStart  DateTime // Monday 00:00 UTC of the week the quest was claimed for
  claimedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questKey, weekStart])
  @@index([userId])
}

// ── Availability ──────────────────────────────────────────────────────────────

model TeacherAvailability {
  id        String @id @default(cuid())
  teacherId String
  dayOfWeek Int    // 0=Sunday … 6=Saturday
  startHour Int
  startMin  Int    // 0 or 30
  endHour   Int
  endMin    Int

  teacher User @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
}
