datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RegularClassStatus {
  active
  inactive
}

enum Status {
  requested
  scheduled
  completed
  refused
}

enum Role {
  admin
  student
  teacher
}

enum NotificationType {
  class_requested
  class_accepted
  class_refused
  class_cancelled
  class_claimed
  class_paid
  class_completed
  tier_up
  rank_up
  badge_earned
  gem_received
  counter_offer_proposed
  counter_offer_accepted
  counter_offer_declined
}

enum BadgeCategory {
  subject
  engagement
  milestone
  expertise
  pedagogy
}

model User {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  email         String    @unique
  emailVerified DateTime?
  password      String
  image         String?
  phoneNumber   String?
  accounts      Account[]
  sessions      Session[]
  role          Role      @default(student)
  bio           String?

  // Teacher-specific fields
  isOnline       Boolean  @default(false)
  pricePerHour   Decimal?
  teachingStyle  String?
  teacherRating  TeacherRating[]  @relation("TeacherRatingStudent")
  teacherSubject TeacherSubject[]

  // Student-specific fields
  learningStyle  String?
  learningGoal   String?
  avatarFrame    String?
  avatarOptions  String?   @db.Text // JSON: AvatarOptions (toon-head customization)

  // Optional for WebAuthn support
  Authenticator Authenticator[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  classesAsStudent        Class[]              @relation("Student")
  classesAsTeacher        Class[]              @relation("Teacher")
  classesAsRequester      Class[]              @relation("Requester")
  regularClassesAsStudent RegularClass[]       @relation("RegularClassStudent")
  regularClassesAsTeacher RegularClass[]       @relation("RegularClassTeacher")
  teacherRatingsAsTeacher TeacherRating[]      @relation("TeacherRatingTeacher")
  paymentsAsStudent       Payment[]            @relation("PaymentStudent")
  paymentsAsTeacher       Payment[]            @relation("PaymentTeacher")
  notifications           Notification[]
  studentGameProfile      StudentGameProfile?
  teacherGameProfile      TeacherGameProfile?
  userBadges              UserBadge[]
  teacherAvailability     TeacherAvailability[]
}

model Subject {
  id             String           @id @default(cuid())
  name           String           @unique
  teacherSubject TeacherSubject[]
  class          Class[]
  regularClass   RegularClass[]
}

model TeacherSubject {
  id        String @id @default(cuid())
  teacherId String
  subjectId String

  teacher User    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])
}

model Class {
  id              String   @id @default(cuid())
  studentId       String
  teacherId       String?
  subjectId       String
  startTime       DateTime
  durationInHours Decimal
  totalPrice      Decimal  @default(0)
  status          Status   @default(requested)
  paid              Boolean  @default(false)
  preAuthIntentId   String?
  requesterId       String
  counterOfferTime  DateTime?
  priority          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  student       User            @relation("Student", fields: [studentId], references: [id], onDelete: Cascade)
  teacher       User?           @relation("Teacher", fields: [teacherId], references: [id], onDelete: Cascade)
  requester     User            @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  subject       Subject         @relation(fields: [subjectId], references: [id])
  teacherRating TeacherRating[]
  payments      Payment[]

  @@index([studentId])
  @@index([teacherId])
  @@index([status])
}

model RegularClass {
  id              String             @id @default(cuid())
  studentId       String
  teacherId       String
  subjectId       String
  dayOfWeek       Int
  startTime       DateTime
  durationInHours Decimal
  totalPrice      Decimal
  status          RegularClassStatus @default(active)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  student User    @relation("RegularClassStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher User    @relation("RegularClassTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@index([studentId])
  @@index([teacherId])
}

model TeacherRating {
  id        String   @id @default(cuid())
  studentId String
  teacherId String
  classId   String
  rating    Decimal  @default(5)
  review    String?
  createdAt DateTime @default(now())

  student User  @relation("TeacherRatingStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher User  @relation("TeacherRatingTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId])
  @@index([teacherId])
}

model Payment {
  id           String   @id @default(cuid())
  studentId    String
  teacherId    String
  classId      String
  amount       Decimal
  intentId     String
  createdAt    DateTime @default(now())

  student User  @relation("PaymentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher User  @relation("PaymentTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([teacherId])
  @@index([classId])
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String  @unique
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?
  user                     User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

// ── Gamification ─────────────────────────────────────────────────────────────

model StudentGameProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  insightGems      Int       @default(0)
  learningTier     Int       @default(0) // 0=Aspiring 1=Dedicated 2=Scholar 3=Luminary 4=Sage
  streakDays       Int       @default(0)
  lastActivityAt   DateTime?
  ownedFrames      String    @default("")  // comma-separated frame keys
  activeFrame      String?                // currently equipped frame key (null = none)
  studyBoostActive Boolean   @default(false)
  priorityBooking  Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TeacherGameProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  reputationSparks Int      @default(0)
  mentorshipRank   Int      @default(0) // 0=Associate 1=Senior 2=Master 3=Elite 4=Global Lead
  profileCompleted Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id          String        @id @default(cuid())
  key         String        @unique
  name        String
  description String
  iconKey     String
  category    BadgeCategory
  userBadges  UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
}

// ── Availability ──────────────────────────────────────────────────────────────

model TeacherAvailability {
  id        String @id @default(cuid())
  teacherId String
  dayOfWeek Int    // 0=Sunday … 6=Saturday
  startHour Int
  startMin  Int    // 0 or 30
  endHour   Int
  endMin    Int

  teacher User @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
}
